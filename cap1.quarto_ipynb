    "---\n",
    "title: \"Capítulo 1: Detecção de Contorno de Dente\"\n",
    "format: html\n",
    "code-fold: true\n",
    "jupyter: python3\n",
    "---"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "4891252e",
   "metadata": {},
   "outputs": [
    {
     "data": {
