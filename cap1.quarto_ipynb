   "source": [
    "import cv2\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from scipy.interpolate import splprep, splev\n",
    "from scipy import ndimage\n",
    "\n",
    "# 1. Carregar imagem\n",
    "# Se a imagem for colorida, o '0' a converte para tons de cinza\n",
    "img_orig = cv2.imread('molarinferior.jpg', 0)\n",
    "\n",
    "if img_orig is None:\n",
    "    print(\"Erro: Arquivo de imagem não encontrado.\")\n",
    "else:\n",
    "    # 2. Aumentar contraste (CLAHE) - Essencial para branco sobre branco\n",
    "    # Isso destaca a \"sombra\" na borda do dente\n",
    "    clahe = cv2.createCLAHE(clipLimit=3.0, tileGridSize=(8, 8))\n",
    "    cl1 = clahe.apply(img_orig)\n",
    "\n",
    "    # 3. Suavizar para reduzir ruído de pixels\n",
    "    blurred = cv2.GaussianBlur(cl1, (5, 5), 0)\n",
    "\n",
    "    # 4. Detecção de Bordas (Canny)\n",
    "    # Ajuste 30 e 100 se a borda sumir ou aparecer muito ruído\n",
    "    edges = cv2.Canny(blurred, 30, 100)\n",
    "\n",
    "    # 1. Dilatar as bordas para fechar qualquer pequeno espaço no contorno externo\n",
    "    kernel = np.ones((5, 5), np.uint8)\n",
    "    dilated = cv2.dilate(edges, kernel, iterations=1)\n",
    "\n",
    "    # 2. Preencher o interior do dente (Transforma a borda em um objeto sólido)\n",
    "    # Isso elimina as \"linhas poluídas\" de dentro do dente\n",
    "\n",
    "    mask = ndimage.binary_fill_holes(dilated).astype(np.uint8) * 255\n",
    "\n",
    "    # 3. Agora extraímos APENAS o contorno externo dessa máscara sólida\n",
    "    contours, _ = cv2.findContours(mask, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)\n",
    "\n",
    "    if len(contours) > 0:\n",
    "        # Pegamos o maior objeto detectado (o dente principal)\n",
    "        cnt = max(contours, key=cv2.contourArea).reshape(-1, 2)\n",
    "\n",
    "        # 4. Suavização Matemática (Spline)\n",
    "        # Aumentamos o 's' para ignorar o \"serrilhado\" da dilatação\n",
    "        tck, u = splprep([cnt[:, 0], cnt[:, 1]], s=50.0, per=True)\n",
    "        u_new = np.linspace(u.min(), u.max(), 1000)\n",
    "        x_new, y_new = splev(u_new, tck)\n",
    "\n",
    "        # 8. Visualização Final\n",
    "        plt.figure(figsize=(12, 6))\n",
    "\n",
    "        plt.subplot(1, 2, 1)\n",
    "        plt.title(\"Contraste Realçado (CLAHE)\")\n",
    "        plt.imshow(cl1, cmap='gray')\n",
    "\n",
    "        plt.subplot(1, 2, 2)\n",
    "        plt.title(\"Curva Matemática sobre a Imagem\")\n",
    "        plt.imshow(img_orig, cmap='gray')\n",
    "        plt.plot(cnt[:, 0], cnt[:, 1], 'ro', markersize=0.5, label='Pixels Detectados', alpha=0.5)\n",
    "        plt.plot(x_new, y_new, 'b-', linewidth=2, label='Curva Spline')\n",
    "        plt.legend()\n",
    "        plt.gca().invert_yaxis()  # Inverter para alinhar coordenadas da imagem\n",
    "\n",
    "        plt.tight_layout()\n",
    "        plt.show()"
   ]
  }
 ],
